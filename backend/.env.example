APP_NAME="Teddy Hospital X-Ray"
SHARED_PASSWORD="change-me"
JWT_SECRET_KEY="replace-with-a-long-random-secret"
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=60

RESULTS_PER_IMAGE=3
CAROUSEL_SIZE=25
CAROUSEL_AUTOPLAY_SECONDS=5
FRACTURE_EDITOR_ENABLED=true
